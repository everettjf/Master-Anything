{
  "name": "master-anything",
  "version": "0.2.0",
  "description": "Learn any codebase to mastery — a knowledge graph plus verifiable Apply/Analyze/Create, in one local app. Run it with: npx master-anything.",
  "type": "module",
  "bin": {
    "master-anything": "./dist/master-anything.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "knowledge-graph",
    "learning",
    "mastery",
    "codebase",
    "tree-sitter",
    "graphrag",
    "tutor",
    "ai",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/everettjf/Master-Anything#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/everettjf/Master-Anything.git",
    "directory": "packages/app"
  },
  "bugs": {
    "url": "https://github.com/everettjf/Master-Anything/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/master-anything.mjs",
    "prepublishOnly": "node build.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "tree-sitter": "^0.22.4",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@ma/core": "workspace:*",
    "@ma/server": "workspace:*",
    "@ma/verifier": "workspace:*",
    "@ma/web": "workspace:*",
    "esbuild": "^0.25.0"
  }
}
