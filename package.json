{
  "name": "master-anything",
  "version": "0.0.0",
  "private": true,
  "description": "Master anything, verifiably. From understanding to mastery.",
  "scripts": {
    "build": "pnpm -r build",
    "pretest": "pnpm --filter @ma/core --filter @ma/verifier build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome check --write .",
    "graph": "pnpm --filter @ma/core graph",
    "server": "pnpm --filter @ma/server dev",
    "web": "pnpm --filter @ma/web dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@ma/core": "workspace:*",
    "@ma/verifier": "workspace:*",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "tree-sitter",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "tree-sitter-typescript"
    ]
  }
}
