# Optional LLM enrichment backend, via the Vercel AI SDK (`ai` + `@ai-sdk/*`).
# Unset -> heuristic summaries. Copy to .env or export in your shell before
# starting @ma/server. Any backend error auto-falls back to heuristics.

# --- A) Named provider (OpenAI / Anthropic / Google) ---
# MA_LLM_PROVIDER=anthropic
# MA_LLM_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_API_KEY=sk-ant-...            # or MA_LLM_API_KEY to override
#
# MA_LLM_PROVIDER=openai   MA_LLM_MODEL=gpt-4o-mini         (OPENAI_API_KEY)
# MA_LLM_PROVIDER=google   MA_LLM_MODEL=gemini-1.5-pro      (GOOGLE_GENERATIVE_AI_API_KEY)

# --- B) Any OpenAI-compatible endpoint (OpenRouter / LiteLLM proxy / Ollama) ---
# Leave MA_LLM_PROVIDER unset and provide a base URL:
# MA_LLM_BASE_URL=https://openrouter.ai/api/v1
# MA_LLM_MODEL=anthropic/claude-3.5-sonnet
# MA_LLM_API_KEY=sk-or-...
#
# LiteLLM proxy:  MA_LLM_BASE_URL=http://localhost:4000     MA_LLM_MODEL=my-model
# Ollama (local): MA_LLM_BASE_URL=http://localhost:11434/v1 MA_LLM_MODEL=llama3.1

# Optional request timeout (ms)
# MA_LLM_TIMEOUT_MS=20000

# --- Persistence ---
# Learner mastery is saved here (default ./.ma-data). Graph artifacts are
# written to <repo>/.master-anything/graph.json so a reconnect skips rebuild.
# MA_DATA_DIR=./.ma-data

# --- Optional: test sandbox for verifiable Apply ---
# local (default) runs pytest as a host subprocess; docker isolates it.
# MA_SANDBOX=docker
# MA_SANDBOX_IMAGE=python:3.11      # image must already contain pytest (network is off)
# MA_SANDBOX_NETWORK=none           # container network (default none)

# --- Optional: semantic retrieval for the Tutor (embeddings) ---
# Unset -> lexical retrieval. Provider: openai | openai-compatible.
# MA_EMBED_PROVIDER=openai
# MA_EMBED_MODEL=text-embedding-3-small
# MA_EMBED_API_KEY=...                     # defaults to MA_LLM_API_KEY
# MA_EMBED_BASE_URL=http://localhost:4000  # for openai-compatible (LiteLLM/Ollama)
