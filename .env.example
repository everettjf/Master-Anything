# Optional LLM backend (Vercel AI SDK). Unset -> heuristic summaries.
# 11 vendors ship as presets; any backend error auto-falls back to heuristics.
# Check what's active at any time:  curl localhost:8787/config

# --- Easiest: just set a provider's key; it's auto-detected ---
# ANTHROPIC_API_KEY=sk-ant-...    # -> anthropic, default model, zero extra config
# OPENAI_API_KEY=sk-...           # -> openai (also enables embeddings)
# (detect priority: anthropic, openai, google, openrouter, groq, deepseek, mistral, xai, together, fireworks)

# --- Pick a preset explicitly (model optional; preset default used if omitted) ---
# MA_LLM_PROVIDER=groq            GROQ_API_KEY=...          # llama-3.3-70b-versatile
# MA_LLM_PROVIDER=deepseek        DEEPSEEK_API_KEY=...      # deepseek-chat
# MA_LLM_PROVIDER=openrouter      OPENROUTER_API_KEY=...    # anthropic/claude-3.5-sonnet
# MA_LLM_PROVIDER=mistral|xai|together|fireworks|google|ollama
# MA_LLM_MODEL=...                # override the preset's default model

# --- Or provider/model in one string (first segment must be a known preset) ---
# MA_LLM_MODEL=anthropic/claude-3-5-sonnet-latest   (+ ANTHROPIC_API_KEY)

# --- Or any OpenAI-compatible endpoint (custom / LiteLLM proxy) ---
# MA_LLM_BASE_URL=http://localhost:4000   MA_LLM_MODEL=my-model   MA_LLM_API_KEY=...

# --- Failover: try the primary, then each fallback on error (openclaw-style) ---
# MA_LLM_FALLBACK=openai,groq

# Optional request timeout (ms)
# MA_LLM_TIMEOUT_MS=20000

# --- Persistence ---
# SQLite holds learner mastery and repo graph artifacts (durable, queryable).
# MA_DATA_DIR=./.ma-data                 # default dir for the DB
# MA_DB=./.ma-data/master-anything.db    # explicit DB path (overrides MA_DATA_DIR)
# A shareable copy of each graph is also written to <repo>/.master-anything/graph.json.

# --- Optional: test sandbox for verifiable Apply ---
# local (default) runs pytest as a host subprocess; docker isolates it.
# MA_SANDBOX=docker
# MA_SANDBOX_IMAGE=python:3.11      # image must already contain pytest (network is off)
# MA_SANDBOX_NETWORK=none           # container network (default none)

# --- Optional: semantic retrieval for the Tutor (embeddings) ---
# Unset -> lexical retrieval. Provider: openai | openai-compatible.
# MA_EMBED_PROVIDER=openai
# MA_EMBED_MODEL=text-embedding-3-small
# MA_EMBED_API_KEY=...                     # defaults to MA_LLM_API_KEY
# MA_EMBED_BASE_URL=http://localhost:4000  # for openai-compatible (LiteLLM/Ollama)
