# Optional LLM enrichment backend (generic OpenAI-compatible).
# Unset -> heuristic summaries. Works with OpenRouter / LiteLLM proxy / Ollama / vLLM / OpenAI.
# Copy to .env and fill in, or export these in your shell before starting @ma/server.

# --- OpenRouter ---
# MA_LLM_BASE_URL=https://openrouter.ai/api/v1
# MA_LLM_MODEL=anthropic/claude-3.5-sonnet
# MA_LLM_API_KEY=sk-or-...

# --- LiteLLM proxy (run: litellm --config litellm.yaml) ---
# MA_LLM_BASE_URL=http://localhost:4000
# MA_LLM_MODEL=my-model
# MA_LLM_API_KEY=sk-...

# --- Ollama (local, no key) ---
# MA_LLM_BASE_URL=http://localhost:11434/v1
# MA_LLM_MODEL=llama3.1

# Optional request timeout (ms)
# MA_LLM_TIMEOUT_MS=20000
